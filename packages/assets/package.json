{
  "name": "@pragyaos/assets",
  "version": "1.0.0",
  "description": "PragyaOS editorial decorative asset library — hand-crafted SVG illustrations for the Marketing Experience",
  "main": "./dist/index.js",
  "module": "./dist/index.mjs",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.mjs",
      "require": "./dist/index.js"
    },
    "./editorial/*": "./editorial/*",
    "./hero/*": "./hero/*"
  },
  "files": [
    "dist",
    "editorial",
    "hero"
  ],
  "scripts": {
    "build": "tsup src/index.tsx --format cjs,esm --dts",
    "dev": "tsup src/index.tsx --format cjs,esm --dts --watch",
    "type-check": "tsc --noEmit"
  },
  "peerDependencies": {
    "react": "^19.0.0"
  },
  "devDependencies": {
    "@pragyaos/typescript-config": "workspace:*",
    "@types/react": "^19.0.0",
    "tsup": "^8.0.0",
    "typescript": "^5.0.0"
  }
}
