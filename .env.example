# API Configurations
PORT=3001
NODE_ENV=development

# Database Configuration (PostgreSQL)
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pragyaos?schema=public"

# Cache Configuration (Redis)
REDIS_URL="redis://localhost:6379"

# Cryptographic Keys
JWT_SECRET="super-secret-development-key-replace-in-production"
JWT_EXPIRE="15m"
JWT_REFRESH_SECRET="another-super-secret-refresh-key-replace-in-production"
JWT_REFRESH_EXPIRE="7d"

# Payment Gateways
RAZORPAY_KEY_ID="rzp_test_change_me"
RAZORPAY_KEY_SECRET="change_me"

# Storage Settings
CLOUDINARY_URL="cloudinary://api_key:api_secret@cloud_name"
