datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(255)
  logoUrl   String?   @map("logo_url") @db.VarChar(512)
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  users    User[]
  settings SystemSetting[]

  @@map("organizations")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String?    @map("first_name") @db.VarChar(100)
  lastName     String?    @map("last_name") @db.VarChar(100)
  status       UserStatus @default(ACTIVE)
  version      Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz
  createdBy    String?    @map("created_by") @db.Uuid
  updatedBy    String?    @map("updated_by") @db.Uuid

  // Authentication Fields
  emailVerified         Boolean   @default(false) @map("email_verified")
  emailVerifiedAt       DateTime? @map("email_verified_at") @db.Timestamptz
  avatarUrl             String?   @map("avatar_url") @db.VarChar(512)
  lastLoginAt           DateTime? @map("last_login_at") @db.Timestamptz
  lastPasswordChangedAt DateTime? @map("last_password_changed_at") @db.Timestamptz
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until") @db.Timestamptz

  // User Profile Fields
  displayName String? @map("display_name") @db.VarChar(100)
  bio         String? @db.Text
  timezone    String? @default("UTC") @db.VarChar(100)
  language    String? @default("en") @db.VarChar(10)
  preferences Json?   @db.JsonB

  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  userRoles         UserRole[]
  auditLogs         AuditLog[]
  instructedCourses CourseInstructor[]

  // Authentication Relations
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]
  media                   Media[]
  enrollments             Enrollment[]
  orders                  Order[]
  couponRedemptions       CouponRedemption[]
  credentials             Credential[]
  revokedCredentials      CredentialRevocation[]   @relation("RevokerRelation")
  notifications           Notification[]
  notificationPreference  NotificationPreference?

  @@index([organizationId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  version     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityName String?  @map("entity_name") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  payload    Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id             String        @id @default(uuid()) @db.Uuid
  key            String        @unique @db.VarChar(255)
  value          String        @db.Text
  description    String?       @db.VarChar(255)
  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  @@index([organizationId])
  @@map("system_settings")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  deviceInfo String?  @map("device_info") @db.VarChar(255)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  revoked    Boolean  @default(false)
  lastUsedAt DateTime @default(now()) @map("last_used_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

enum CourseVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LearningUnitType {
  VIDEO
  ARTICLE
  PDF
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
  EXTERNAL_LINK
  CODE_LAB
}

enum MediaProvider {
  LOCAL
  CLOUDFLARE_R2
  CLOUDFLARE_STREAM
}

enum MediaStatus {
  PENDING
  UPLOADING
  UPLOADED
  PROCESSING
  READY
  FAILED
  DELETED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  ARCHIVE
  OTHER
}

model Media {
  id        String        @id @default(uuid()) @db.Uuid
  type      MediaType
  provider  MediaProvider @default(LOCAL)
  bucket    String?       @db.VarChar(100)
  key       String        @unique @db.VarChar(512)
  mimeType  String        @map("mime_type") @db.VarChar(100)
  size      BigInt
  hash      String?       @db.VarChar(64) // SHA-256 integrity hash
  status    MediaStatus   @default(UPLOADING)
  metadata  Json?         @db.JsonB // Provider-agnostic metadata (dimensions, duration, waveforms, codecs, etc.)
  version   Int           @default(1)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  userId    String?       @map("user_id") @db.Uuid

  // Relations
  user              User?              @relation(fields: [userId], references: [id], onDelete: SetNull)
  coursesThumbnail  Course[]           @relation("CourseThumbnail")
  coursesTrailer    Course[]           @relation("CourseTrailer")
  learningUnits     LearningUnit[]
  learningResources LearningResource[]

  @@index([userId])
  @@map("media")
}

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  parentId    String?  @map("parent_id") @db.Uuid
  name        String   @db.VarChar(100)
  slug        String   @unique @db.VarChar(120)
  description String?  @db.Text
  version     Int      @default(1)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  parent        Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  subCategories Category[] @relation("CategoryHierarchy")
  courses       Course[]

  @@unique([parentId, name])
  @@map("categories")
}

model Course {
  id                String           @id @default(uuid()) @db.Uuid
  categoryId        String           @map("category_id") @db.Uuid
  slug              String           @unique @db.VarChar(255)
  title             String           @db.VarChar(255)
  subtitle          String?          @db.VarChar(512)
  description       String?          @db.Text
  language          String           @default("en") @db.VarChar(10)
  difficulty        DifficultyLevel  @default(BEGINNER)
  estimatedDuration Int              @default(0) @map("estimated_duration") // Minutes
  thumbnailId       String?          @map("thumbnail_id") @db.Uuid
  trailerId         String?          @map("trailer_id") @db.Uuid
  seoMetadata       Json?            @map("seo_metadata") @db.JsonB
  status            CourseStatus     @default(DRAFT)
  visibility        CourseVisibility @default(PUBLIC)
  featured          Boolean          @default(false)
  version           Int              @default(1)
  revisionNumber    Int              @default(1) @map("revision_number")
  changeSummary     String?          @map("change_summary") @db.Text
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  publishedAt       DateTime?        @map("published_at") @db.Timestamptz

  // Relations
  category  Category @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  thumbnail Media?   @relation("CourseThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  trailer   Media?   @relation("CourseTrailer", fields: [trailerId], references: [id], onDelete: SetNull)

  modules      CourseModule[]
  instructors  CourseInstructor[]
  requirements CourseRequirement[]
  objectives   CourseObjective[]
  faqs         CourseFAQ[]
  tags         CourseTag[]
  enrollments  Enrollment[]
  credentials  Credential[]

  @@index([categoryId])
  @@index([status, visibility])
  @@map("courses")
}

model Tag {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @unique @db.VarChar(100)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  courses CourseTag[]

  @@map("tags")
}

model CourseTag {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([courseId, tagId])
  @@map("course_tags")
}

model CourseInstructor {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@map("course_instructors")
}

model CourseRequirement {
  id          String @id @default(uuid()) @db.Uuid
  courseId    String @map("course_id") @db.Uuid
  description String @db.VarChar(512)
  sequence    Int    @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_requirements")
}

model CourseObjective {
  id          String @id @default(uuid()) @db.Uuid
  courseId    String @map("course_id") @db.Uuid
  description String @db.VarChar(512)
  sequence    Int    @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_objectives")
}

model CourseFAQ {
  id       String @id @default(uuid()) @db.Uuid
  courseId String @map("course_id") @db.Uuid
  question String @db.VarChar(512)
  answer   String @db.Text
  sequence Int    @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_faqs")
}

model CourseModule {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  sequence    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningUnits LearningUnit[]

  @@map("course_modules")
}

model LearningUnit {
  id          String           @id @default(uuid()) @db.Uuid
  moduleId    String           @map("module_id") @db.Uuid
  title       String           @db.VarChar(255)
  description String?          @db.Text
  type        LearningUnitType
  sequence    Int              @default(0)
  mediaId     String?          @map("media_id") @db.Uuid
  content     Json?            @map("content") @db.JsonB // Structured content block for rich-text editor nodes
  duration    Int              @default(0) // Minutes
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  media  Media?       @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  resources LearningResource[]
  progress  LearningProgress[]
  sessions  LearningSession[]

  @@map("learning_units")
}

model LearningResource {
  id             String @id @default(uuid()) @db.Uuid
  learningUnitId String @map("learning_unit_id") @db.Uuid
  mediaId        String @map("media_id") @db.Uuid
  title          String @db.VarChar(255)
  sequence       Int    @default(0)

  // Relations
  learningUnit LearningUnit @relation(fields: [learningUnitId], references: [id], onDelete: Cascade)
  media        Media        @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@map("learning_resources")
}

enum EnrollmentStatus {
  ACTIVE
  CANCELLED
  SUSPENDED
  COMPLETED
}

enum ProgressStatus {
  NOT_STARTED
  STARTED
  COMPLETED
}

enum SessionStatus {
  ACTIVE
  COMPLETED
  ABANDONED
}

enum TimelineEventType {
  COURSE_STARTED
  MODULE_STARTED
  UNIT_STARTED
  UNIT_COMPLETED
  QUIZ_COMPLETED
  ASSIGNMENT_SUBMITTED
  COURSE_COMPLETED
  ENROLLMENT_CANCELLED
  ENROLLMENT_SUSPENDED
  ENROLLMENT_RESUMED
}

enum CourseCompletionReason {
  COMPLETED_ALL_UNITS
  MANUALLY_COMPLETED
  ADMIN_OVERRIDE
}

model Enrollment {
  id          String           @id @default(uuid()) @db.Uuid
  userId      String           @map("user_id") @db.Uuid
  courseId    String           @map("course_id") @db.Uuid
  status      EnrollmentStatus @default(ACTIVE)
  source      String           @default("MANUAL") @db.VarChar(50)
  purchaseRef String?          @map("purchase_ref") @db.VarChar(100)
  enrolledAt  DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz
  completedAt DateTime?        @map("completed_at") @db.Timestamptz
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  user       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  course     Course             @relation(fields: [courseId], references: [id], onDelete: Cascade)
  progress   LearningProgress[]
  sessions   LearningSession[]
  timeline   LearningTimeline[]
  completion CourseCompletion?

  @@unique([userId, courseId])
  @@index([userId])
  @@index([courseId])
  @@map("enrollments")
}

model LearningProgress {
  id                String         @id @default(uuid()) @db.Uuid
  enrollmentId      String         @map("enrollment_id") @db.Uuid
  learningUnitId    String         @map("learning_unit_id") @db.Uuid
  status            ProgressStatus @default(NOT_STARTED)
  completionPercent Float          @default(0) @map("completion_percent")
  watchTime         Int            @default(0) @map("watch_time") // Seconds
  lastPosition      Int            @default(0) @map("last_position") // Seconds playback or scroll location
  lastViewedAt      DateTime?      @map("last_viewed_at") @db.Timestamptz
  completedAt       DateTime?      @map("completed_at") @db.Timestamptz
  createdAt         DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  learningUnit LearningUnit @relation(fields: [learningUnitId], references: [id], onDelete: Restrict)

  @@unique([enrollmentId, learningUnitId])
  @@index([enrollmentId])
  @@index([learningUnitId])
  @@map("learning_progress")
}

model LearningSession {
  id             String        @id @default(uuid()) @db.Uuid
  enrollmentId   String        @map("enrollment_id") @db.Uuid
  learningUnitId String?       @map("learning_unit_id") @db.Uuid
  device         String?       @db.VarChar(100)
  browser        String?       @db.VarChar(100)
  ipAddress      String?       @map("ip_address") @db.VarChar(45)
  userAgent      String?       @map("user_agent") @db.VarChar(512)
  status         SessionStatus @default(ACTIVE)
  startedAt      DateTime      @default(now()) @map("started_at") @db.Timestamptz
  endedAt        DateTime?     @map("ended_at") @db.Timestamptz
  duration       Int? // seconds
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  enrollment   Enrollment    @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)
  learningUnit LearningUnit? @relation(fields: [learningUnitId], references: [id], onDelete: SetNull)

  @@index([enrollmentId])
  @@index([learningUnitId])
  @@map("learning_sessions")
}

model LearningTimeline {
  id           String            @id @default(uuid()) @db.Uuid
  enrollmentId String            @map("enrollment_id") @db.Uuid
  eventType    TimelineEventType @map("event_type")
  metadata     Json?             @db.JsonB
  createdAt    DateTime          @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([enrollmentId])
  @@map("learning_timeline")
}

model CourseCompletion {
  id                        String                 @id @default(uuid()) @db.Uuid
  enrollmentId              String                 @unique @map("enrollment_id") @db.Uuid
  progressPercent           Float                  @default(0) @map("progress_percent")
  completedAt               DateTime?              @map("completed_at") @db.Timestamptz
  eligibleForCertificate    Boolean                @default(false) @map("eligible_for_certificate")
  estimatedRemainingSeconds Int                    @default(0) @map("estimated_remaining_seconds")
  reason                    CourseCompletionReason @default(COMPLETED_ALL_UNITS)
  createdAt                 DateTime               @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                 DateTime               @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@map("course_completions")
}

enum ProductType {
  COURSE
  BUNDLE
  MEMBERSHIP
  DIGITAL_DOWNLOAD
  CERTIFICATE
}

enum ProductStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

enum PriceType {
  ONE_TIME
  RECURRING
}

enum OrderStatus {
  CREATED
  PENDING_PAYMENT
  PAID
  FAILED
  CANCELLED
  REFUNDED
}

enum PaymentGateway {
  RAZORPAY
  STRIPE
  MANUAL
}

enum PaymentStatus {
  PENDING
  SUCCESS
  FAILED
}

enum RefundStatus {
  PENDING
  SUCCESS
  FAILED
}

enum CouponType {
  PERCENTAGE
  FLAT
}

enum CouponStatus {
  ACTIVE
  EXPIRED
  EXHAUSTED
  INACTIVE
}

enum WebhookEventStatus {
  RECEIVED
  PROCESSED
  FAILED
}

model WebhookEvent {
  id          String             @id @default(uuid()) @db.Uuid
  eventId     String             @unique @map("event_id") @db.VarChar(100)
  provider    String             @db.VarChar(50)
  payload     Json               @db.JsonB
  signature   String?            @db.Text
  receivedAt  DateTime           @default(now()) @map("received_at") @db.Timestamptz
  processedAt DateTime?          @map("processed_at") @db.Timestamptz
  status      WebhookEventStatus @default(RECEIVED)

  @@map("webhook_events")
}

model Product {
  id           String        @id @default(uuid()) @db.Uuid
  sellableId   String        @map("sellable_id") @db.Uuid
  sellableType ProductType   @map("sellable_type")
  sku          String        @unique @db.VarChar(255)
  status       ProductStatus @default(DRAFT)
  version      Int           @default(1)
  createdAt    DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime      @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?     @map("deleted_at") @db.Timestamptz
  createdBy    String?       @map("created_by") @db.Uuid
  updatedBy    String?       @map("updated_by") @db.Uuid

  // Relations
  prices     ProductPrice[]
  orderItems OrderItem[]

  @@index([sellableId, sellableType])
  @@index([status])
  @@map("products")
}

model ProductPrice {
  id              String    @id @default(uuid()) @db.Uuid
  productId       String    @map("product_id") @db.Uuid
  currency        String    @db.VarChar(3)
  amount          Int       @db.Integer // Stored in smallest currency unit (cents/paise)
  priceType       PriceType @map("price_type")
  billingInterval String?   @map("billing_interval") @db.VarChar(50)
  active          Boolean   @default(true)
  effectiveFrom   DateTime  @default(now()) @map("effective_from") @db.Timestamptz
  effectiveTo     DateTime? @map("effective_to") @db.Timestamptz
  version         Int       @default(1)
  createdAt       DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt       DateTime? @map("deleted_at") @db.Timestamptz
  createdBy       String?   @map("created_by") @db.Uuid
  updatedBy       String?   @map("updated_by") @db.Uuid

  // Relations
  product    Product     @relation(fields: [productId], references: [id], onDelete: Restrict)
  orderItems OrderItem[]

  @@index([productId])
  @@map("product_prices")
}

model Coupon {
  id               String       @id @default(uuid()) @db.Uuid
  code             String       @unique @db.VarChar(50)
  discountType     CouponType   @map("discount_type")
  discountValue    Int          @map("discount_value") // Integer percent or flat cents
  minOrderValue    Int          @default(0) @map("min_order_value")
  usageLimit       Int?         @map("usage_limit")
  redemptionsCount Int          @default(0) @map("redemptions_count")
  perUserLimit     Int          @default(1) @map("per_user_limit")
  exclusive        Boolean      @default(true)
  status           CouponStatus @default(ACTIVE)
  expiresAt        DateTime?    @map("expires_at") @db.Timestamptz
  active           Boolean      @default(true)
  scopeConstraints Json?        @map("scope_constraints") @db.JsonB // e.g. { productIds: [...], categoryIds: [...] }
  version          Int          @default(1)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt        DateTime?    @map("deleted_at") @db.Timestamptz
  createdBy        String?      @map("created_by") @db.Uuid
  updatedBy        String?      @map("updated_by") @db.Uuid

  // Relations
  redemptions CouponRedemption[]
  orders      Order[]

  @@map("coupons")
}

model CouponRedemption {
  id        String   @id @default(uuid()) @db.Uuid
  couponId  String   @map("coupon_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  orderId   String   @map("order_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  coupon Coupon @relation(fields: [couponId], references: [id], onDelete: Restrict)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  order  Order  @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@unique([userId, couponId, orderId])
  @@index([userId])
  @@index([couponId])
  @@index([orderId])
  @@map("coupon_redemptions")
}

model Order {
  id                     String      @id @default(uuid()) @db.Uuid
  orderNumber            String      @unique @map("order_number") @db.VarChar(50)
  userId                 String      @map("user_id") @db.Uuid
  status                 OrderStatus @default(CREATED)
  currency               String      @db.VarChar(3)
  subtotalAmount         Int         @map("subtotal_amount")
  discountAmount         Int         @default(0) @map("discount_amount")
  taxAmount              Int         @default(0) @map("tax_amount")
  netAmount              Int         @map("net_amount")
  activeCouponId         String?     @map("active_coupon_id") @db.Uuid
  customerNameSnapshot   String      @map("customer_name_snapshot") @db.VarChar(255)
  customerEmailSnapshot  String      @map("customer_email_snapshot") @db.VarChar(255)
  billingAddressSnapshot String?     @map("billing_address_snapshot") @db.Text
  version                Int         @default(1)
  createdAt              DateTime    @default(now()) @map("created_at") @db.Timestamptz
  updatedAt              DateTime    @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt              DateTime?   @map("deleted_at") @db.Timestamptz
  createdBy              String?     @map("created_by") @db.Uuid
  updatedBy              String?     @map("updated_by") @db.Uuid

  // Relations
  user        User               @relation(fields: [userId], references: [id], onDelete: Restrict)
  coupon      Coupon?            @relation(fields: [activeCouponId], references: [id], onDelete: Restrict)
  items       OrderItem[]
  payments    PaymentAttempt[]
  invoice     Invoice?
  redemptions CouponRedemption[]
  fulfillmentExecutions FulfillmentExecution[]

  @@index([userId])
  @@index([status])
  @@map("orders")
}

model OrderItem {
  id               String @id @default(uuid()) @db.Uuid
  orderId          String @map("order_id") @db.Uuid
  productId        String @map("product_id") @db.Uuid
  priceId          String @map("price_id") @db.Uuid
  priceSnapshot    Int    @map("price_snapshot")
  discountSnapshot Int    @default(0) @map("discount_snapshot")
  quantity         Int    @default(1)

  // Relations
  order   Order        @relation(fields: [orderId], references: [id], onDelete: Cascade)
  product Product      @relation(fields: [productId], references: [id], onDelete: Restrict)
  price   ProductPrice @relation(fields: [priceId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([productId])
  @@index([priceId])
  @@map("order_items")
}

model PaymentAttempt {
  id               String         @id @default(uuid()) @db.Uuid
  orderId          String         @map("order_id") @db.Uuid
  gateway          PaymentGateway
  gatewayOrderId   String?        @map("gateway_order_id") @db.VarChar(100)
  gatewayPaymentId String?        @unique @map("gateway_payment_id") @db.VarChar(100)
  status           PaymentStatus  @default(PENDING)
  amount           Int
  errorCode        String?        @map("error_code") @db.VarChar(100)
  errorDescription String?        @map("error_description") @db.VarChar(255)
  createdAt        DateTime       @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime       @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  order   Order    @relation(fields: [orderId], references: [id], onDelete: Restrict)
  refunds Refund[]
  fulfillmentExecutions FulfillmentExecution[]

  @@index([orderId])
  @@index([gatewayOrderId])
  @@map("payment_attempts")
}

model Invoice {
  id             String   @id @default(uuid()) @db.Uuid
  invoiceNumber  String   @unique @map("invoice_number") @db.VarChar(50)
  orderId        String   @unique @map("order_id") @db.Uuid
  issuedAt       DateTime @default(now()) @map("issued_at") @db.Timestamptz
  taxDetails     Json?    @map("tax_details") @db.JsonB
  billingAddress String?  @map("billing_address") @db.Text
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  order Order @relation(fields: [orderId], references: [id], onDelete: Restrict)

  @@map("invoices")
}

model Refund {
  id               String       @id @default(uuid()) @db.Uuid
  paymentAttemptId String       @map("payment_attempt_id") @db.Uuid
  gatewayRefundId  String?      @unique @map("gateway_refund_id") @db.VarChar(100)
  status           RefundStatus @default(PENDING)
  amount           Int
  reason           String?      @db.Text
  version          Int          @default(1)
  createdAt        DateTime     @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime     @updatedAt @map("updated_at") @db.Timestamptz
  createdBy        String?      @map("created_by") @db.Uuid
  updatedBy        String?      @map("updated_by") @db.Uuid

  // Relations
  paymentAttempt PaymentAttempt @relation(fields: [paymentAttemptId], references: [id], onDelete: Restrict)

  @@index([paymentAttemptId])
  @@map("refunds")
}

enum FulfillmentStatus {
  PENDING
  STARTED
  PARTIALLY_COMPLETED
  COMPLETED
  FAILED
  DEAD_LETTER
}

model FulfillmentExecution {
  id               String            @id @default(uuid()) @db.Uuid
  orderId          String            @map("order_id") @db.Uuid
  paymentAttemptId String            @map("payment_attempt_id") @db.Uuid
  status           FulfillmentStatus @default(PENDING)
  currentStep      String?           @map("current_step") @db.VarChar(100)
  retryCount       Int               @default(0) @map("retry_count")
  startedAt        DateTime          @default(now()) @map("started_at") @db.Timestamptz
  completedAt      DateTime?         @map("completed_at") @db.Timestamptz
  correlationId    String            @map("correlation_id") @db.VarChar(100)
  errorMessage     String?           @map("error_message") @db.Text

  // Relations
  order          Order          @relation(fields: [orderId], references: [id], onDelete: Restrict)
  paymentAttempt PaymentAttempt @relation(fields: [paymentAttemptId], references: [id], onDelete: Restrict)

  @@index([orderId])
  @@index([status])
  @@map("fulfillment_executions")
}

enum CredentialStatus {
  PENDING
  ISSUED
  REVOKED
  EXPIRED
}

enum VerificationSource {
  PUBLIC_PAGE
  API
  ADMIN
}

model CredentialTemplate {
  id              String   @id @default(uuid()) @db.Uuid
  name            String   @db.VarChar(255)
  slug            String   @unique @db.VarChar(255)
  templateVersion String   @map("template_version") @db.VarChar(50)
  htmlTemplate    String   @map("html_template") @db.Text
  cssTemplate     String   @map("css_template") @db.Text
  branding        Json?    @db.JsonB
  active          Boolean  @default(true)
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime @updatedAt @map("updated_at") @db.Timestamptz

  credentials Credential[]

  @@map("credential_templates")
}

model Credential {
  id                String           @id @default(uuid()) @db.Uuid
  credentialNumber  String           @unique @map("credential_number") @db.VarChar(100)
  userId            String           @map("user_id") @db.Uuid
  courseId          String           @map("course_id") @db.Uuid
  templateId        String           @map("template_id") @db.Uuid
  issuedAt          DateTime         @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt         DateTime?        @map("expires_at") @db.Timestamptz
  verificationToken String           @unique @map("verification_token") @db.VarChar(255)
  verificationHash  String           @map("verification_hash") @db.VarChar(255)
  status            CredentialStatus @default(PENDING)
  metadata          Json             @default("{}") @db.JsonB
  revision          Int              @default(1)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user         User                   @relation(fields: [userId], references: [id], onDelete: Restrict)
  course       Course                 @relation(fields: [courseId], references: [id], onDelete: Restrict)
  template     CredentialTemplate     @relation(fields: [templateId], references: [id], onDelete: Restrict)
  verifications CredentialVerification[]
  revocation   CredentialRevocation?

  @@index([userId])
  @@index([courseId])
  @@index([templateId])
  @@map("credentials")
}

model CredentialVerification {
  id           String             @id @default(uuid()) @db.Uuid
  credentialId String             @map("credential_id") @db.Uuid
  verifiedAt   DateTime           @default(now()) @map("verified_at") @db.Timestamptz
  ipAddress    String?            @map("ip_address") @db.VarChar(45)
  userAgent    String?            @map("user_agent") @db.VarChar(512)
  source       VerificationSource
  success      Boolean

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Cascade)

  @@index([credentialId])
  @@map("credential_verifications")
}

model CredentialRevocation {
  id           String   @id @default(uuid()) @db.Uuid
  credentialId String   @unique @map("credential_id") @db.Uuid
  reason       String?  @db.Text
  revokedBy    String   @map("revoked_by") @db.Uuid
  revokedAt    DateTime @default(now()) @map("revoked_at") @db.Timestamptz
  metadata     Json     @default("{}") @db.JsonB

  credential Credential @relation(fields: [credentialId], references: [id], onDelete: Restrict)
  revoker    User       @relation("RevokerRelation", fields: [revokedBy], references: [id], onDelete: Restrict)

  @@map("credential_revocations")
}

// ─────────────────────────────────────────────────────────────────────────
// Notification & Communication Platform
// ─────────────────────────────────────────────────────────────────────────

enum NotificationChannel {
  IN_APP
  EMAIL
  PUSH
  SMS
}

enum NotificationStatus {
  PENDING
  QUEUED
  SENT
  DELIVERED
  READ
  FAILED
}

enum NotificationPriority {
  LOW
  NORMAL
  HIGH
  CRITICAL
}

enum NotificationCategory {
  SYSTEM
  SECURITY
  COURSE
  LEARNING
  PAYMENT
  CREDENTIAL
  MEDIA
  MARKETING
}

model NotificationTemplate {
  id            String              @id @default(uuid()) @db.Uuid
  name          String              @db.VarChar(255)
  slug          String              @db.VarChar(255)
  version       Int                 @default(1)
  channel       NotificationChannel
  locale        String              @default("en") @db.VarChar(10)
  titleTemplate String              @map("title_template") @db.VarChar(512)
  bodyTemplate  String              @map("body_template") @db.Text
  variables     Json                @default("[]") @db.JsonB
  active        Boolean             @default(true)
  createdAt     DateTime            @default(now()) @map("created_at") @db.Timestamptz
  updatedAt     DateTime            @updatedAt @map("updated_at") @db.Timestamptz

  notifications Notification[]

  @@unique([slug, channel, locale, version])
  @@index([slug, channel, locale])
  @@map("notification_templates")
}

model Notification {
  id            String               @id @default(uuid()) @db.Uuid
  userId        String               @map("user_id") @db.Uuid
  templateId    String?              @map("template_id") @db.Uuid
  dedupeKey     String?              @unique @map("dedupe_key") @db.VarChar(512)
  title         String               @db.VarChar(512)
  body          String               @db.Text
  category      NotificationCategory
  priority      NotificationPriority @default(NORMAL)
  channel       NotificationChannel
  status        NotificationStatus   @default(PENDING)
  payload       Json                 @default("{}") @db.JsonB
  correlationId String?              @map("correlation_id") @db.VarChar(255)
  scheduledAt   DateTime?            @map("scheduled_at") @db.Timestamptz
  deliveredAt   DateTime?            @map("delivered_at") @db.Timestamptz
  readAt        DateTime?            @map("read_at") @db.Timestamptz
  expiresAt     DateTime?            @map("expires_at") @db.Timestamptz
  revision      Int                  @default(1)
  createdAt     DateTime             @default(now()) @map("created_at") @db.Timestamptz

  user      User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  template  NotificationTemplate? @relation(fields: [templateId], references: [id], onDelete: SetNull)
  deliveries NotificationDelivery[]

  @@index([userId, status])
  @@index([userId, createdAt])
  @@index([correlationId])
  @@map("notifications")
}

model NotificationPreference {
  id                    String   @id @default(uuid()) @db.Uuid
  userId                String   @unique @map("user_id") @db.Uuid
  channelPreferences    Json     @default("{}") @map("channel_preferences") @db.JsonB
  categoryPreferences   Json     @default("{}") @map("category_preferences") @db.JsonB
  marketingOptIn        Boolean  @default(true) @map("marketing_opt_in")
  digestEnabled         Boolean  @default(false) @map("digest_enabled")
  createdAt             DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notification_preferences")
}

model NotificationDelivery {
  id                String    @id @default(uuid()) @db.Uuid
  notificationId    String    @map("notification_id") @db.Uuid
  provider          String    @db.VarChar(100)
  providerMessageId String?   @map("provider_message_id") @db.VarChar(255)
  providerStatus    String?   @map("provider_status") @db.VarChar(100)
  retryCount        Int       @default(0) @map("retry_count")
  failureReason     String?   @map("failure_reason") @db.Text
  deliveredAt       DateTime? @map("delivered_at") @db.Timestamptz
  createdAt         DateTime  @default(now()) @map("created_at") @db.Timestamptz

  notification Notification @relation(fields: [notificationId], references: [id], onDelete: Cascade)

  @@index([notificationId])
  @@map("notification_deliveries")
}
