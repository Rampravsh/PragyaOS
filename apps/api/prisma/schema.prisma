datasource db {
  provider = "postgresql"
}

generator client {
  provider = "prisma-client-js"
}

enum UserStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
}

model Organization {
  id        String    @id @default(uuid()) @db.Uuid
  name      String    @db.VarChar(255)
  slug      String    @unique @db.VarChar(255)
  logoUrl   String?   @map("logo_url") @db.VarChar(512)
  version   Int       @default(0)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime  @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt DateTime? @map("deleted_at") @db.Timestamptz
  createdBy String?   @map("created_by") @db.Uuid
  updatedBy String?   @map("updated_by") @db.Uuid

  users    User[]
  settings SystemSetting[]

  @@map("organizations")
}

model User {
  id           String     @id @default(uuid()) @db.Uuid
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash") @db.VarChar(255)
  firstName    String?    @map("first_name") @db.VarChar(100)
  lastName     String?    @map("last_name") @db.VarChar(100)
  status       UserStatus @default(ACTIVE)
  version      Int        @default(0)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime   @updatedAt @map("updated_at") @db.Timestamptz
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz
  createdBy    String?    @map("created_by") @db.Uuid
  updatedBy    String?    @map("updated_by") @db.Uuid

  // Authentication Fields
  emailVerified         Boolean   @default(false) @map("email_verified")
  emailVerifiedAt       DateTime? @map("email_verified_at") @db.Timestamptz
  avatarUrl             String?   @map("avatar_url") @db.VarChar(512)
  lastLoginAt           DateTime? @map("last_login_at") @db.Timestamptz
  lastPasswordChangedAt DateTime? @map("last_password_changed_at") @db.Timestamptz
  failedLoginAttempts   Int       @default(0) @map("failed_login_attempts")
  lockedUntil           DateTime? @map("locked_until") @db.Timestamptz

  // User Profile Fields
  displayName           String?   @map("display_name") @db.VarChar(100)
  bio                   String?   @db.Text
  timezone              String?   @default("UTC") @db.VarChar(100)
  language              String?   @default("en") @db.VarChar(10)
  preferences           Json?     @db.JsonB

  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Restrict)

  userRoles         UserRole[]
  auditLogs         AuditLog[]
  instructedCourses CourseInstructor[]

  // Authentication Relations
  refreshTokens           RefreshToken[]
  passwordResetTokens     PasswordResetToken[]
  emailVerificationTokens EmailVerificationToken[]

  @@index([organizationId])
  @@map("users")
}

model Role {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  version     Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  userRoles       UserRole[]
  rolePermissions RolePermission[]

  @@map("roles")
}

model Permission {
  id          String   @id @default(uuid()) @db.Uuid
  name        String   @unique @db.VarChar(100)
  description String?  @db.VarChar(255)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  rolePermissions RolePermission[]

  @@map("permissions")
}

model UserRole {
  userId    String   @map("user_id") @db.Uuid
  roleId    String   @map("role_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  role Role @relation(fields: [roleId], references: [id], onDelete: Cascade)

  @@id([userId, roleId])
  @@index([roleId])
  @@map("user_roles")
}

model RolePermission {
  roleId       String   @map("role_id") @db.Uuid
  permissionId String   @map("permission_id") @db.Uuid
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  role       Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@id([roleId, permissionId])
  @@index([permissionId])
  @@map("role_permissions")
}

model AuditLog {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String?  @map("user_id") @db.Uuid
  action     String   @db.VarChar(100)
  entityName String?  @map("entity_name") @db.VarChar(100)
  entityId   String?  @map("entity_id") @db.Uuid
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  payload    Json?    @db.JsonB
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([createdAt])
  @@map("audit_logs")
}

model SystemSetting {
  id             String        @id @default(uuid()) @db.Uuid
  key            String        @unique @db.VarChar(255)
  value          String        @db.Text
  description    String?       @db.VarChar(255)
  organizationId String?       @map("organization_id") @db.Uuid
  organization   Organization? @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  createdAt      DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  @@index([organizationId])
  @@map("system_settings")
}

model RefreshToken {
  id         String   @id @default(uuid()) @db.Uuid
  userId     String   @map("user_id") @db.Uuid
  tokenHash  String   @unique @map("token_hash") @db.VarChar(255)
  deviceInfo String?  @map("device_info") @db.VarChar(255)
  ipAddress  String?  @map("ip_address") @db.VarChar(45)
  userAgent  String?  @map("user_agent") @db.VarChar(512)
  expiresAt  DateTime @map("expires_at") @db.Timestamptz
  revoked    Boolean  @default(false)
  lastUsedAt DateTime @default(now()) @map("last_used_at") @db.Timestamptz
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt  DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

model PasswordResetToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  revoked   Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("password_reset_tokens")
}

model EmailVerificationToken {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  tokenHash String   @unique @map("token_hash") @db.VarChar(255)
  expiresAt DateTime @map("expires_at") @db.Timestamptz
  used      Boolean  @default(false)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("email_verification_tokens")
}

enum CourseStatus {
  DRAFT
  REVIEW
  PUBLISHED
  ARCHIVED
}

enum CourseVisibility {
  PUBLIC
  PRIVATE
  UNLISTED
}

enum DifficultyLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum LearningUnitType {
  VIDEO
  ARTICLE
  PDF
  QUIZ
  ASSIGNMENT
  LIVE_SESSION
  EXTERNAL_LINK
  CODE_LAB
}

enum MediaProvider {
  LOCAL
  CLOUDFLARE_R2
  CLOUDFLARE_STREAM
}

enum MediaStatus {
  PENDING
  READY
  PROCESSING
  FAILED
}

enum MediaType {
  IMAGE
  VIDEO
  DOCUMENT
  AUDIO
  ARCHIVE
  OTHER
}

model Media {
  id        String        @id @default(uuid()) @db.Uuid
  type      MediaType
  provider  MediaProvider @default(LOCAL)
  bucket    String?       @db.VarChar(100)
  key       String        @unique @db.VarChar(512)
  mimeType  String        @map("mime_type") @db.VarChar(100)
  size      BigInt
  hash      String?       @db.VarChar(64) // SHA-256 integrity hash
  status    MediaStatus   @default(READY)
  metadata  Json?         @db.JsonB // Provider-agnostic metadata (dimensions, duration, waveforms, codecs, etc.)
  version   Int           @default(1)
  createdAt DateTime      @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime      @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  coursesThumbnail Course[]           @relation("CourseThumbnail")
  coursesTrailer   Course[]           @relation("CourseTrailer")
  learningUnits    LearningUnit[]
  learningResources LearningResource[]

  @@map("media")
}

model Category {
  id          String    @id @default(uuid()) @db.Uuid
  parentId    String?   @map("parent_id") @db.Uuid
  name        String    @db.VarChar(100)
  slug        String    @unique @db.VarChar(120)
  description String?   @db.Text
  version     Int       @default(1)
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  parent         Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  subCategories  Category[] @relation("CategoryHierarchy")
  courses        Course[]

  @@unique([parentId, name])
  @@map("categories")
}

model Course {
  id                String           @id @default(uuid()) @db.Uuid
  categoryId        String           @map("category_id") @db.Uuid
  slug              String           @unique @db.VarChar(255)
  title             String           @db.VarChar(255)
  subtitle          String?          @db.VarChar(512)
  description       String?          @db.Text
  language          String           @default("en") @db.VarChar(10)
  difficulty        DifficultyLevel  @default(BEGINNER)
  estimatedDuration Int              @default(0) @map("estimated_duration") // Minutes
  thumbnailId       String?          @map("thumbnail_id") @db.Uuid
  trailerId         String?          @map("trailer_id") @db.Uuid
  seoMetadata       Json?            @map("seo_metadata") @db.JsonB
  status            CourseStatus     @default(DRAFT)
  visibility        CourseVisibility @default(PUBLIC)
  featured          Boolean          @default(false)
  version           Int              @default(1)
  createdAt         DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime         @updatedAt @map("updated_at") @db.Timestamptz
  publishedAt       DateTime?        @map("published_at") @db.Timestamptz

  // Relations
  category    Category     @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  thumbnail   Media?       @relation("CourseThumbnail", fields: [thumbnailId], references: [id], onDelete: SetNull)
  trailer     Media?       @relation("CourseTrailer", fields: [trailerId], references: [id], onDelete: SetNull)

  modules      CourseModule[]
  instructors  CourseInstructor[]
  requirements CourseRequirement[]
  objectives   CourseObjective[]
  faqs         CourseFAQ[]
  tags         CourseTag[]

  @@index([categoryId])
  @@index([status, visibility])
  @@map("courses")
}

model Tag {
  id        String      @id @default(uuid()) @db.Uuid
  name      String      @unique @db.VarChar(100)
  createdAt DateTime    @default(now()) @map("created_at") @db.Timestamptz

  courses   CourseTag[]

  @@map("tags")
}

model CourseTag {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  tagId     String   @map("tag_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  tag    Tag    @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@unique([courseId, tagId])
  @@map("course_tags")
}

model CourseInstructor {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([courseId, userId])
  @@index([userId])
  @@map("course_instructors")
}

model CourseRequirement {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  description String   @db.VarChar(512)
  sequence    Int      @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_requirements")
}

model CourseObjective {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  description String   @db.VarChar(512)
  sequence    Int      @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_objectives")
}

model CourseFAQ {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  question  String   @db.VarChar(512)
  answer    String   @db.Text
  sequence  Int      @default(0)

  // Relations
  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_faqs")
}

model CourseModule {
  id          String   @id @default(uuid()) @db.Uuid
  courseId    String   @map("course_id") @db.Uuid
  title       String   @db.VarChar(255)
  description String?  @db.Text
  sequence    Int      @default(0)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  course        Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  learningUnits LearningUnit[]

  @@map("course_modules")
}

model LearningUnit {
  id          String           @id @default(uuid()) @db.Uuid
  moduleId    String           @map("module_id") @db.Uuid
  title       String           @db.VarChar(255)
  description String?          @db.Text
  type        LearningUnitType
  sequence    Int              @default(0)
  mediaId     String?          @map("media_id") @db.Uuid
  content     Json?            @map("content") @db.JsonB // Structured content block for rich-text editor nodes
  duration    Int              @default(0) // Minutes
  createdAt   DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt   DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  // Relations
  module CourseModule @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  media  Media?       @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  resources LearningResource[]

  @@map("learning_units")
}

model LearningResource {
  id             String   @id @default(uuid()) @db.Uuid
  learningUnitId String   @map("learning_unit_id") @db.Uuid
  mediaId        String   @map("media_id") @db.Uuid
  title          String   @db.VarChar(255)
  sequence       Int      @default(0)

  // Relations
  learningUnit LearningUnit @relation(fields: [learningUnitId], references: [id], onDelete: Cascade)
  media        Media        @relation(fields: [mediaId], references: [id], onDelete: Restrict)

  @@map("learning_resources")
}

