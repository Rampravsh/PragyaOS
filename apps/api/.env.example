PORT=3001
NODE_ENV=development

# Database Settings
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/pragyaos?schema=public"

# Redis Cache Settings
REDIS_URL="redis://localhost:6379"

# Security Tokens
JWT_SECRET="super-secret-development-key-change-me-please"
JWT_EXPIRE="15m"
JWT_REFRESH_SECRET="another-super-secret-refresh-key-change-me"
JWT_REFRESH_EXPIRE="7d"

# Security Constraints
CORS_ORIGIN="*"
RATE_LIMIT_WINDOW_MS=60000
RATE_LIMIT_MAX=100

# Integrations (Optional for Core)
CLOUDINARY_URL=""
RAZORPAY_KEY_ID=""
RAZORPAY_KEY_SECRET=""
