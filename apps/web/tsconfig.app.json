{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "@pragyaos/typescript-config/vite.json",
  "compilerOptions": {
    "noEmit": true,
    "composite": false,
    "noUnusedLocals": true,
    "noUnusedParameters": true,
    "noFallthroughCasesInSwitch": true,
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src"]
}
